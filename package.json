{
  "name": "astroagent-backend",
  "version": "1.0.0",
  "description": "AstroAgent backend — LangGraph + Swiss Ephemeris + MongoDB",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec \"ts-node --transpile-only\" src/index.ts",
    "build": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc",
    "start": "node dist/index.js",
    "typecheck": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/langgraph-checkpoint-mongodb": "^0.0.5",
    "@langchain/openai": "^0.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "geo-tz": "^8.0.0",
    "luxon": "^3.5.0",
    "mongodb": "^6.9.0",
    "mongoose": "^8.7.0",
    "node-geocoder": "^4.4.0",
    "sweph": "2.10.3-5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.0.0",
    "@types/node-geocoder": "^4.2.6",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
